# Example environment variables for local development and Vercel.
# This project does not require any app-specific env vars by default.
# Add values here only when you need server or public configuration.

# Example server-only values (never expose secrets to the browser)
# DATABASE_URL=
# STRIPE_SECRET_KEY=

# Example public values for the client (must be prefixed with VITE_)
# VITE_PUBLIC_API_URL=
# VITE_ANALYTICS_KEY=

# Vercel sets NODE_ENV automatically to production during builds.
# NODE_ENV=production
